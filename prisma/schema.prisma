generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model JournalEntry {
  id              String    @id @default(uuid())
  user_id         String
  track           String
  title           String?
  content         String?
  mood            String?
  gratitude_items String[]
  goals           Json?
  habits          Json?
  tags            String[]
  is_private      Boolean   @default(false)
  prompt_used     String?
  dream_time      String?
  entry_date      DateTime
  created_date    DateTime  @default(now())
  updated_date    DateTime  @updatedAt

  @@index([user_id])
  @@index([user_id, entry_date])
  @@map("journal_entries")
}

model Journal {
  id           String   @id @default(uuid())
  user_id      String
  track        String
  name         String
  description  String?
  cover_emoji  String?
  created_date DateTime @default(now())
  updated_date DateTime @updatedAt
  pages        Page[]

  @@index([user_id])
  @@map("journals")
}

model Page {
  id              String   @id @default(uuid())
  user_id         String
  journal_id      String
  track           String
  title           String?
  content         String?
  mood            String?
  gratitude_items String[]
  goals           Json?
  habits          Json?
  tags            String[]
  is_private      Boolean  @default(false)
  prompt_used     String?
  dream_time      String?
  entry_date      DateTime
  created_date    DateTime @default(now())
  updated_date    DateTime @updatedAt
  journal         Journal  @relation(fields: [journal_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([journal_id])
  @@map("pages")
}

model JournalingGoal {
  id             String    @id @default(uuid())
  user_id        String
  title          String
  description    String?
  target_type    String
  target_value   Float
  track          String?
  completed      Boolean   @default(false)
  completed_date DateTime?
  created_date   DateTime  @default(now())
  updated_date   DateTime  @updatedAt

  @@index([user_id])
  @@map("journaling_goals")
}

model UserProfile {
  id                      String   @id @default(uuid())
  user_id                 String   @unique
  first_name              String?
  age_range               String?
  gender                  String?
  industry                String?
  job_title               String?
  journaling_goal         String?
  journaling_experience   String?
  reflection_time         String?
  notification_preference String?
  enrolled_tracks         String[]
  track_sensitivity       Json?
  selected_modes          String[] @default([])
  onboarding_preferences  Json?
  daily_play_goal_minutes Int?
  onboarding_completed    Boolean  @default(false)
  created_date            DateTime @default(now())
  updated_date            DateTime @updatedAt

  @@map("user_profiles")
}

model ChildProfile {
  id                  String   @id @default(uuid())
  user_id             String
  name                String
  birthdate           DateTime
  known_allergens     String[] @default([])
  developmental_focus String[] @default([])
  profile             Json?
  created_date        DateTime @default(now())
  updated_date        DateTime @updatedAt

  @@index([user_id])
  @@map("child_profiles")
}
